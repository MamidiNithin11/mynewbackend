<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Status</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f6f8;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .box {
      background: #fff;
      padding: 30px;
      width: 100%;
      max-width: 420px;
      text-align: center;
      border-radius: 8px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    h2 {
      color: #28a745;
      margin-bottom: 20px;
    }

    .error {
      color: #dc3545;
    }

    a {
      display: inline-block;
      text-decoration: none;
      background: #007bff;
      color: white;
      padding: 10px 18px;
      border-radius: 5px;
      margin-top: 10px;
    }

    a:hover {
      background: #0056b3;
    }
  </style>
</head>
<body>
  <div class="box">
    <a href="/api/auth/login" method="POST">Go to Login</a>
  </div>
</body>
</html>
